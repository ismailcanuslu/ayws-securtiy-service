{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "KeycloakSettings": {
    "BaseUrl": "http://localhost:8080",
    "Realm": "master",
    "AdminClientId": "ayws-admin",
    "AdminClientSecret": "YOUR_KEYCLOAK_ADMIN_CLIENT_SECRET",
    "TokenUrl": "http://localhost:8080/realms/master/protocol/openid-connect/token"
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=ayws_security;Username=postgres;Password=postgres"
  },
  "EncryptionSettings": {
    "SecretEncryptionKey": "REPLACE_WITH_BASE64_ENCODED_32_BYTE_KEY_FOR_AES256"
  }
}