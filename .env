# ─────────────────────────────────────────────
# AYWS — Environment Variables
# Kopyala: cp .env.example .env
# ─────────────────────────────────────────────

# ── Keycloak ──────────────────────────────────
KEYCLOAK_VERSION=24.0.3

KC_DB=postgres
KC_DB_URL=jdbc:postgresql://keycloak-db:5432/keycloak
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=changeme_keycloak_db_pass

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme_admin_pass

#KC_BOOTSTRAP_ADMIN_USERNAME=admin
#KC_BOOTSTRAP_ADMIN_PASSWORD=c

KC_HOSTNAME=localhost
KC_HOSTNAME_PORT=8080
KC_HOSTNAME_STRICT=false
KC_HOSTNAME_STRICT_HTTPS=false
KC_HTTP_ENABLED=true

# Üretimde true yap, HTTP'yi kapat
KC_PROXY=edge
KC_LOG_LEVEL=INFO

# ── Keycloak PostgreSQL ────────────────────────
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=changeme_keycloak_db_pass
KEYCLOAK_DB_PORT=5433          # host'tan erişim için (container içi 5432)

# ── AYWS Master Realm ─────────────────────────
# Keycloak ilk açılışta bu realm otomatik oluşur (master)
# Tenant realm'ları security-service tarafından runtime'da oluşturulur

# ── Security Service ──────────────────────────
SECURITY_SERVICE_PORT=5001
SECURITY_SERVICE_DB_HOST=security-db
SECURITY_SERVICE_DB_PORT=5432
SECURITY_SERVICE_DB_NAME=ayws_security
SECURITY_SERVICE_DB_USER=ayws_security
SECURITY_SERVICE_DB_PASSWORD=changeme_security_db_pass

# Keycloak Admin API erişimi için service-account
KEYCLOAK_ADMIN_CLIENT_ID=ayws-security-service
KEYCLOAK_ADMIN_CLIENT_SECRET=changeme_client_secret

# ── PgAdmin (opsiyonel, geliştirme) ───────────
PGADMIN_DEFAULT_EMAIL=admin@ayws.com.tr
PGADMIN_DEFAULT_PASSWORD=changeme_pgadmin_pass
PGADMIN_PORT=5050